# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=uae_real_estate

# Scraper
MODE=incremental
# Requests per minute (uniform distribution)
RATE_LIMIT_RPM=8
# Max concurrent workers
CONCURRENCY=2
# Circuit breaker: consecutive existing listings before early exit
CIRCUIT_BREAK_THRESHOLD=50

# API Server
API_PORT=3000

# Logging
LOG_LEVEL=info
