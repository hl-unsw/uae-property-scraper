# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=your_password_here
MONGO_PORT=27018
MONGO_URI=mongodb://admin:your_password_here@127.0.0.1:27018
MONGO_DB_NAME=uae_real_estate

# Scraper
MODE=incremental
# 每分钟请求数（均匀分布）
RATE_LIMIT_RPM=8
# 最大并发 worker 数
CONCURRENCY=2
# 熔断器：连续已存在房源数达到此阈值后停止翻页
CIRCUIT_BREAK_THRESHOLD=50

# API Server
API_PORT=3000

# WebAuthn / Auth
# Generate with: openssl rand -hex 32
HMAC_SECRET=
# One-time token for Touch ID registration (any string)
ADMIN_TOKEN=
# Auto-detected as "localhost" locally; set to your domain on Vercel
# WEBAUTHN_RP_ID=uae-property-scraper.vercel.app
# Set after running Touch ID registration
# WEBAUTHN_CREDENTIAL_ID=
# WEBAUTHN_PUBLIC_KEY=

# Dubizzle Scraper (Pure HTTP / Algolia direct)
DUBIZZLE_MODE=incremental
# Delay between Algolia API calls (ms)
DUBIZZLE_PAGE_DELAY_MS=1000
# Incremental mode circuit breaker threshold
DUBIZZLE_CIRCUIT_BREAK_THRESHOLD=50

# Bayut Scraper
BAYUT_MODE=incremental
# true = headless Chromium; false = headed mode for debugging
BAYUT_HEADLESS=true
# Delay between page navigations (ms)
BAYUT_PAGE_DELAY_MS=5000
# Max Humbucker re-challenge attempts per session
BAYUT_MAX_RECHALLENGE=3
# Incremental mode circuit breaker threshold
BAYUT_CIRCUIT_BREAK_THRESHOLD=50

# Logging
LOG_LEVEL=info
