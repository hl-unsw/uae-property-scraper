{
  "name": "uae-property-scraper",
  "version": "1.0.0",
  "description": "UAE property rental data scraper & dashboard (Property Finder, Dubizzle, Bayut)",
  "main": "src/scraper/index.js",
  "scripts": {
    "scrape:full": "MODE=full node src/scraper/index.js",
    "scrape:incremental": "MODE=incremental node src/scraper/index.js",
    "server": "node src/api/server.js",
    "dev": "concurrently \"npm run server\" \"npm run scrape:incremental\"",
    "db:setup": "docker compose up -d",
    "db:stop": "docker compose down"
  },
  "keywords": [
    "uae",
    "property",
    "scraper",
    "rental"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "async-sema": "^3.1.1",
    "axios": "^1.13.5",
    "axios-cookiejar-support": "^6.0.5",
    "cheerio": "^1.2.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongodb": "^7.1.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tough-cookie": "^6.0.0"
  }
}
