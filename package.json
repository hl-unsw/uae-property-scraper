{
  "name": "uae-property-scraper",
  "version": "1.0.0",
  "description": "UAE property rental data scraper & dashboard (Property Finder, Dubizzle, Bayut)",
  "main": "src/scraper/index.js",
  "scripts": {
    "scrape:full": "MODE=full node src/scraper/index.js",
    "scrape:incremental": "MODE=incremental node src/scraper/index.js",
    "server": "node src/api/server.js",
    "dev": "concurrently \"npm run server\" \"npm run scrape:incremental\"",
    "db:setup": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:migrate": "node scripts/migrations/runner.js",
    "db:migrate:status": "node scripts/migrations/runner.js --status",
    "db:migrate:rollback": "node scripts/migrations/runner.js --rollback",
    "db:backup": "bash scripts/migrations/backup.sh dump",
    "db:restore": "bash scripts/migrations/backup.sh restore",
    "db:backup:list": "bash scripts/migrations/backup.sh list",
    "scrape:dubizzle:full": "DUBIZZLE_MODE=full node src/scraper-dubizzle/index.js",
    "scrape:dubizzle:incremental": "DUBIZZLE_MODE=incremental node src/scraper-dubizzle/index.js",
    "scrape:bayut:full": "BAYUT_MODE=full node src/scraper-bayut/index.js",
    "scrape:bayut:incremental": "BAYUT_MODE=incremental node src/scraper-bayut/index.js",
    "scrape:bayut:debug": "BAYUT_MODE=full BAYUT_HEADLESS=false node src/scraper-bayut/index.js",
    "search:targeted": "node src/scripts/targeted-search.js",
    "export:json": "node scripts/export-to-json.js",
    "deploy:data": "./scripts/pipeline.sh",
    "test": "jest --verbose",
    "test:stale": "jest --verbose tests/stale-"
  },
  "keywords": [
    "uae",
    "property",
    "scraper",
    "rental"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@simplewebauthn/server": "^13.2.2",
    "async-sema": "^3.1.1",
    "axios": "^1.13.5",
    "axios-cookiejar-support": "^6.0.5",
    "cheerio": "^1.2.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongodb": "^7.1.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.50.0",
    "tough-cookie": "^6.0.0"
  },
  "devDependencies": {
    "jest": "^30.2.0"
  }
}
